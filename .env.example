# Copy this file to ".env" and fill in your real values.

# REQUIRED: Bot token from Discord Dev Portal -> your app -> "Bot" tab -> "Reset Token"
DISCORD_TOKEN=

# REQUIRED: your server (guild) ID. Right-click your server icon -> Copy Server ID
# (needs Developer Mode on: User Settings -> Advanced -> Developer Mode)
GUILD_ID=

# OPTIONAL onboarding config (matched by NAME, case-insensitive)
# Role automatically given to every new member:
ROOKIE_ROLE_NAME=Rookie
# Channel where ALGO posts the welcome message (falls back to the server's system channel):
WELCOME_CHANNEL_NAME=welcome
# Channel where ALGO logs moderation actions (optional; leave blank to disable):
MODLOG_CHANNEL_NAME=mod-log
